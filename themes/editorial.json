      "style": "normal"
    },
    {
      "family": "Work Sans",
      "path": "assets/fonts/google/work-sans/work-sans-400.woff2",
      "weight": 400,
      "style": "normal"
    },
    {
      "family": "Work Sans",
      "path": "assets/fonts/google/work-sans/work-sans-500.woff2",
      "weight": 500,
      "style": "normal"
    },
    {
      "family": "Work Sans",
      "path": "assets/fonts/google/work-sans/work-sans-600.woff2",
      "weight": 600,
      "style": "normal"
    },
    {
      "family": "Work Sans",
      "path": "assets/fonts/google/work-sans/work-sans-700.woff2",
      "weight": 700,
      "style": "normal"
