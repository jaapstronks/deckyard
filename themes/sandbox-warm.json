    { "family": "Red Hat Display", "path": "assets/fonts/google/red-hat-display/red-hat-display-500.woff2", "weight": 500, "style": "normal" },
    { "family": "Red Hat Display", "path": "assets/fonts/google/red-hat-display/red-hat-display-700.woff2", "weight": 700, "style": "normal" },
    { "family": "Red Hat Display", "path": "assets/fonts/google/red-hat-display/red-hat-display-900.woff2", "weight": 900, "style": "normal" },
    { "family": "Figtree", "path": "assets/fonts/google/figtree/figtree-400.woff2", "weight": 400, "style": "normal" },
    { "family": "Figtree", "path": "assets/fonts/google/figtree/figtree-500.woff2", "weight": 500, "style": "normal" },
    { "family": "Figtree", "path": "assets/fonts/google/figtree/figtree-600.woff2", "weight": 600, "style": "normal" },
    { "family": "Figtree", "path": "assets/fonts/google/figtree/figtree-700.woff2", "weight": 700, "style": "normal" }
  ],
  "hiddenSlideTypes": []
