  "cssVars": {
    "--t-slide-bg-lime": "#fff7ed",
    "--t-slide-bg-mist": "#ffedd5",
    "--t-slide-bg-dark": "#431407",
    "--t-color-background": "#fff7ed",
    "--t-color-text": "#1c1917",
    "--t-color-text-muted": "rgba(28, 25, 23, 0.66)",
    "--t-color-accent": "#c2410c",
    "--t-quote-author-color": "#9a3412",
    "--t-quote-text-color": "#1c1917",
    "--t-radius": "24px",
    "--t-radius-sm": "16px",
    "--t-radius-lg": "32px",
    "--t-font-heading": "'Red Hat Display', 'Figtree', ui-sans-serif, system-ui, sans-serif",
