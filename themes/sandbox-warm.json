    "--t-font-caption": "var(--t-font-body)",
    "--t-font-mono": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace",
    "--t-heading-transform": "none",
    "--t-heading-weight": "900",
    "--t-icon-card-grid-icon-bg": "#ffedd5",
    "--t-chart-0": "#9a3412",
    "--t-chart-1": "#c2410c",
    "--t-chart-2": "#ea580c",
    "--t-chart-3": "#fb923c",
    "--t-chart-4": "#1c1917",
    "--t-chart-5": "#78716c",
    "--t-chart-6": "#44403c",
