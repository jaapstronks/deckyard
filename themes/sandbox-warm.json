{
  "id": "sandbox-warm",
  "label": "Terracotta",
  "defaultTitleSlide": "title-slide",
  "assets": {
    "logo": "/assets/images/logo-placeholder.svg",
    "logoAlt": "Your logo",
    "payoffLogo": "/assets/images/logo-placeholder.svg",
    "payoffAlt": "Your logo"
  },
  "textColorLight": "#ffffff",
  "textColorDark": "#1c1917",
  "brandColors": ["#9a3412", "#c2410c", "#ea580c", "#f97316"],
  "gradient": { "enabled": false },
  "slides": {
    "card-stack-slide": { "colors": ["#9a3412", "#c2410c", "#ea580c", "#f97316"] }
