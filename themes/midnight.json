{
  "id": "midnight",
  "label": "Midnight",
  "defaultTitleSlide": "title-slide",
  "titleLayout": "center",
  "assets": {
    "logo": "/assets/images/logo-placeholder.svg",
    "logoAlt": "Your logo",
    "payoffLogo": "/assets/images/logo-placeholder.svg",
    "payoffAlt": "Your logo"
  },
  "textColorLight": "#fafafa",
  "textColorDark": "#1c1917",
  "backgroundLabels": {
    "lime": {
      "en": "Ink",
      "nl": "Inkt"
    },
    "mist": {
      "en": "Charcoal",
      "nl": "Antraciet"
    }
  },
  "brandColors": [
    "#38bdf8",
    "#818cf8",
    "#f472b6",
    "#fbbf24"
  ],
  "gradient": {
    "enabled": true
  },
  "slides": {
    "card-stack-slide": {
      "colors": [
        "#38bdf8",
        "#818cf8",
        "#f472b6",
        "#fbbf24"
      ]
    }
  },
  "cssVars": {
    "--t-slide-bg-lime": "#18181b",
    "--t-slide-bg-mist": "#27272a",
    "--t-slide-bg-dark": "#09090b",
    "--t-color-background": "#09090b",
    "--t-color-text": "#fafafa",
    "--t-color-text-muted": "rgba(250, 250, 250, 0.64)",
    "--t-color-accent": "#38bdf8",
    "--t-quote-author-color": "#7dd3fc",
    "--t-quote-text-color": "#fafafa",
    "--t-radius": "12px",
    "--t-radius-sm": "8px",
    "--t-radius-lg": "18px",
    "--t-font-heading": "'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif",
    "--t-font-body": "'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif",
    "--t-font-caption": "var(--t-font-body)",
    "--t-font-mono": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
    "--t-heading-transform": "uppercase",
    "--t-heading-weight": "500",
    "--t-icon-card-grid-icon-bg": "#38bdf8",
    "--t-icon-card-grid-body-bg": "#f4f4f5",
    "--t-chart-0": "#38bdf8",
    "--t-chart-1": "#818cf8",
    "--t-chart-2": "#f472b6",
    "--t-chart-3": "#fbbf24",
    "--t-chart-4": "#34d399",
    "--t-chart-5": "#fafafa",
    "--t-chart-6": "#a1a1aa",
    "--t-chart-7": "#c084fc",
    "--t-logo-url": "url('/assets/images/logo-placeholder.svg')"
  },
  "embedFonts": [
    {
      "family": "Space Grotesk",
      "path": "assets/fonts/google/space-grotesk/space-grotesk-400.woff2",
      "weight": 400,
      "style": "normal"
    },
    {
      "family": "Space Grotesk",
      "path": "assets/fonts/google/space-grotesk/space-grotesk-500.woff2",
      "weight": 500,
      "style": "normal"
    },
    {
      "family": "Space Grotesk",
      "path": "assets/fonts/google/space-grotesk/space-grotesk-700.woff2",
      "weight": 700,
      "style": "normal"
    },
    {
      "family": "Inter",
      "path": "assets/fonts/google/inter/inter-400.woff2",
      "weight": 400,
      "style": "normal"
    },
    {
      "family": "Inter",
      "path": "assets/fonts/google/inter/inter-500.woff2",
      "weight": 500,
      "style": "normal"
    },
    {
      "family": "Inter",
      "path": "assets/fonts/google/inter/inter-600.woff2",
      "weight": 600,
      "style": "normal"
    },
    {
      "family": "Inter",
      "path": "assets/fonts/google/inter/inter-700.woff2",
      "weight": 700,
      "style": "normal"
    },
    {
      "family": "JetBrains Mono",
      "path": "assets/fonts/google/jetbrains-mono/jetbrains-mono-400.woff2",
      "weight": 400,
      "style": "normal"
    }
  ],
  "hiddenSlideTypes": []
}
