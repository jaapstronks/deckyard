{
  "id": "sandbox-sage",
  "label": "Sage",
  "defaultTitleSlide": "title-slide",
  "assets": {
    "logo": "/assets/images/logo-placeholder.svg",
    "logoAlt": "Your logo",
    "payoffLogo": "/assets/images/logo-placeholder.svg",
    "payoffAlt": "Your logo"
  },
  "textColorLight": "#ffffff",
  "textColorDark": "#0f172a",
  "backgroundLabels": {
    "lime": {
      "en": "Mint",
      "nl": "Mint"
    },
    "mist": {
      "en": "Sage",
      "nl": "Salie"
    }
  },
  "brandColors": [
    "#14532d",
    "#166534",
    "#15803d",
    "#22c55e"
  ],
  "gradient": {
    "enabled": false
  },
  "slides": {
    "card-stack-slide": {
      "colors": [
        "#14532d",
        "#166534",
        "#15803d",
        "#22c55e"
      ]
    }
  },
  "cssVars": {
    "--t-slide-bg-lime": "#f0fdf4",
    "--t-slide-bg-mist": "#dcfce7",
    "--t-slide-bg-dark": "#14532d",
    "--t-color-background": "#ffffff",
    "--t-color-text": "#0f172a",
    "--t-color-text-muted": "rgba(15, 23, 42, 0.62)",
    "--t-color-accent": "#166534",
    "--t-quote-author-color": "#15803d",
    "--t-quote-text-color": "#0f172a",
    "--t-radius": "8px",
    "--t-radius-sm": "4px",
    "--t-radius-lg": "12px",
    "--t-font-heading": "'Playfair Display', serif",
    "--t-font-body": "'DM Sans', ui-sans-serif, system-ui, sans-serif",
    "--t-font-caption": "var(--t-font-body)",
    "--t-font-mono": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace",
    "--t-heading-transform": "none",
    "--t-heading-weight": "600",
    "--t-icon-card-grid-icon-bg": "#f0fdf4",
    "--t-chart-0": "#14532d",
    "--t-chart-1": "#166534",
    "--t-chart-2": "#15803d",
    "--t-chart-3": "#4ade80",
    "--t-chart-4": "#0f172a",
    "--t-chart-5": "#64748b",
    "--t-chart-6": "#334155",
    "--t-chart-7": "#86efac",
    "--t-logo-url": "url('/assets/images/logo-placeholder.svg')"
  },
  "embedFonts": [
    {
      "family": "Playfair Display",
      "path": "assets/fonts/google/playfair-display/playfair-display-400.woff2",
      "weight": 400,
      "style": "normal"
    },
    {
      "family": "Playfair Display",
      "path": "assets/fonts/google/playfair-display/playfair-display-600.woff2",
      "weight": 600,
      "style": "normal"
    },
    {
      "family": "Playfair Display",
      "path": "assets/fonts/google/playfair-display/playfair-display-700.woff2",
      "weight": 700,
      "style": "normal"
    },
    {
      "family": "DM Sans",
      "path": "assets/fonts/google/dm-sans/dm-sans-400.woff2",
      "weight": 400,
      "style": "normal"
    },
    {
      "family": "DM Sans",
      "path": "assets/fonts/google/dm-sans/dm-sans-500.woff2",
      "weight": 500,
      "style": "normal"
    },
    {
      "family": "DM Sans",
      "path": "assets/fonts/google/dm-sans/dm-sans-700.woff2",
      "weight": 700,
      "style": "normal"
    }
  ],
  "hiddenSlideTypes": []
}
