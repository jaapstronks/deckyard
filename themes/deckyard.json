{
  "id": "deckyard",
  "label": "Deckyard",
  "defaultTitleSlide": "title-slide",
  "assets": {
    "logo": "/assets/images/deckyard-mark.svg",
    "logoAlt": "Deckyard",
    "payoffLogo": "/assets/images/deckyard-mark.svg",
    "payoffAlt": "Deckyard"
  },
  "textColorLight": "#ffffff",
  "textColorDark": "#111827",
  "brandColors": ["#5b21b6", "#7c3aed", "#a78bfa", "#c4b5fd"],
  "gradient": {
    "enabled": false
  },
  "slideBackgrounds": [
    {
      "id": "calm",
      "label": "Calm",
      "value": "radial-gradient(circle at 62% 18%, rgba(124, 58, 237, 0.5) 0%, rgba(124, 58, 237, 0.16) 38%, rgba(0, 0, 0, 0) 72%), radial-gradient(circle at 12% 88%, rgba(91, 33, 182, 0.45) 0%, rgba(91, 33, 182, 0.12) 44%, rgba(0, 0, 0, 0) 78%), #140a26",
      "textColor": "#ffffff",
      "textColorMuted": "rgba(255, 255, 255, 0.72)"
    }
  ],
  "slides": {
    "card-stack-slide": {
      "colors": ["#5b21b6", "#7c3aed", "#a78bfa", "#c4b5fd"]
    }
  },
  "cssVars": {
    "--t-slide-bg-lime": "#ffffff",
    "--t-slide-bg-mist": "#ede9fe",
    "--t-slide-bg-dark": "#2e1065",
    "--t-color-background": "#ffffff",
    "--t-color-text": "#111827",
    "--t-color-text-muted": "rgba(55, 65, 81, 0.82)",
    "--t-color-accent": "#7c3aed",
    "--t-quote-author-color": "#c4b5fd",
    "--t-radius": "16px",
    "--t-radius-sm": "12px",
    "--t-radius-lg": "20px",
    "--t-font-heading": "'Bricolage Grotesque', Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif",
    "--t-font-body": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif",
    "--t-font-caption": "var(--t-font-body)",
    "--t-font-mono": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace",
    "--t-heading-transform": "none",
    "--t-heading-weight": "700",
    "--t-icon-card-grid-icon-bg": "#ede9fe",
    "--t-icon-card-grid-body-bg": "#f5f3ff",
    "--t-chart-0": "#5b21b6",
    "--t-chart-1": "#7c3aed",
    "--t-chart-2": "#a78bfa",
    "--t-chart-3": "#c4b5fd",
    "--t-chart-4": "#111827",
    "--t-chart-5": "#6b7280",
    "--t-chart-6": "#374151",
    "--t-chart-7": "#ddd6fe",
    "--t-logo-url": "url('/assets/images/deckyard-mark.svg')"
  },
  "embedFonts": [
    { "family": "Bricolage Grotesque", "path": "assets/fonts/google/bricolage-grotesque/bricolage-grotesque-400.woff2", "weight": 400, "style": "normal" },
    { "family": "Bricolage Grotesque", "path": "assets/fonts/google/bricolage-grotesque/bricolage-grotesque-600.woff2", "weight": 600, "style": "normal" },
    { "family": "Bricolage Grotesque", "path": "assets/fonts/google/bricolage-grotesque/bricolage-grotesque-700.woff2", "weight": 700, "style": "normal" },
    { "family": "Inter", "path": "assets/fonts/google/inter/inter-400.woff2", "weight": 400, "style": "normal" },
    { "family": "Inter", "path": "assets/fonts/google/inter/inter-500.woff2", "weight": 500, "style": "normal" },
    { "family": "Inter", "path": "assets/fonts/google/inter/inter-600.woff2", "weight": 600, "style": "normal" },
    { "family": "Inter", "path": "assets/fonts/google/inter/inter-700.woff2", "weight": 700, "style": "normal" }
  ],
  "hiddenSlideTypes": [],
  "backgroundPresets": [
    "/assets/images/backgrounds/demo-aurora.jpg",
    "/assets/images/backgrounds/demo-dusk.jpg",
    "/assets/images/backgrounds/demo-paper.jpg",
    "/assets/images/backgrounds/demo-moss.jpg"
  ]
}
