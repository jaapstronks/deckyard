# Deckyard Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Server
# ============================================
# PORT=4177
# DEFAULT_THEME=deckyard
# Max accepted JSON request-body size in bytes (default 25 MB). Bounds memory
# use against oversized bodies; raise it only if you save very large decks.
# MAX_REQUEST_BODY_BYTES=26214400

# Branding / white-label (optional)
# APP_NAME sets the product name in the browser tab title, the logo alt text,
# email sender name, and social/OG cards. Defaults to "Deckyard".
# APP_NAME=Deckyard
# HELP_URL adds a "Help & docs" link to the user menu. Must be an absolute
# http(s) URL; when unset the link is hidden.
# HELP_URL=https://docs.yourdomain.com

# ============================================
# AI Wizard (optional - enable AI features)
# ============================================
# OPENAI_API=sk-...
# OPENAI_MODEL=gpt-4o
# CLAUDE_API=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-5          # generation/fill default
# CLAUDE_MODEL_PLAN=claude-opus-4-8   # deck outline/plan step (defaults to opus)
# MISTRAL_API=...
# MISTRAL_MODEL=mistral-large-latest
# DEEPSEEK_API=sk-...
# DEEPSEEK_MODEL=deepseek-chat

# OpenAI-compatible endpoint (Ollama, Together AI, Fireworks, vLLM, etc.)
# OPENAI_COMPAT_ENDPOINT=http://localhost:11434/v1/chat/completions
# OPENAI_COMPAT_API=                  (optional - not needed for Ollama)
# OPENAI_COMPAT_MODEL=qwen2.5:72b
# OPENAI_COMPAT_LABEL=Ollama          (optional - display name in UI)

# ============================================
# Real-time collaboration (optional)
# ============================================
# Mounts a Yjs/Hocuspocus WebSocket endpoint at /collab and shows live
# collaborator presence in the editor. Off by default; single-user installs
# don't need it.
# COLLAB_ENABLED=true
# Phase 2 (experimental): live document edits — the Y.Doc becomes the live
# source of truth while a deck is open collaboratively, persisted server-side
# and serialized back to the deck JSON. Requires COLLAB_ENABLED.
# COLLAB_LIVE_EDITS=true

# ============================================
# Authentication (recommended for production)
# ============================================
# Set AUTH_SECRET to enable authentication (users are managed in the database;
# the AUTH_ADMIN_EMAIL user gets the admin role).
#
# Secure-by-default: the server REFUSES TO START if AUTH_SECRET is missing,
# UNLESS you explicitly opt out of auth with AUTH_ENABLED=false (or run in
# sandbox/demo mode). This prevents accidentally running wide open with
# anonymous admin access. To run intentionally without auth, set
# AUTH_ENABLED=false.
#
# AUTH_SECRET must be at least 32 characters. Session tokens are HMAC-signed
# with it, so a short secret is brute-forceable/forgeable; the server refuses
# to start below the 32-char floor. If you must boot with a shorter secret
# temporarily, set AUTH_ALLOW_WEAK_SECRET=true (NOT recommended; rotate to a
# strong secret instead). Generate one with e.g. `openssl rand -base64 48`.
# AUTH_SECRET=generate-a-random-secret-here
# AUTH_ADMIN_EMAIL=admin@example.com
# AUTH_ENABLED=false   # run intentionally without auth (anonymous admin)
# AUTH_ALLOW_WEAK_SECRET=true   # escape hatch: boot with a sub-32-char secret
# SECURE_COOKIES=true
# COOKIE_DOMAIN=.yourdomain.com
# CSRF: cookie-authenticated state-changing requests must come from a same-origin
# request (Origin/Referer host must match the app Host, APP_URL, or DOMAIN). Add
# extra trusted origins here (comma-separated) if a partner site legitimately
# posts to the API with the session cookie.
# CSRF_ALLOWED_ORIGINS=https://embed.partner.com

# Development only: skip auth entirely (auto-login as admin).
# Only takes effect when NODE_ENV=development — a leftover AUTH_DEV_BYPASS in a
# staging/production (or unset-NODE_ENV) environment is ignored, so it can never
# silently grant passwordless admin outside local dev.
# NODE_ENV=development
# AUTH_DEV_BYPASS=true

# ============================================
# Single sign-on (SSO) — self-hosted, one IdP (OIDC)
# ============================================
# Point the whole install at one OIDC provider (Google Workspace, Entra ID,
# Okta, Auth0, Keycloak, ...). Users click "Sign in with SSO", authenticate at
# the IdP, and land in the same email-keyed authorization world as password /
# magic-link users. Full guide: docs/reference/sso-oidc.md
#
# The server REFUSES TO START if SSO_ENABLED=true but the OIDC settings are
# incomplete (a half-configured SSO is worse than a clear boot error).
# SSO_ENABLED=true
# SSO_PROVIDER=oidc
# OIDC_ISSUER_URL=https://login.example.com   # discovery via /.well-known/openid-configuration
# OIDC_CLIENT_ID=...
# OIDC_CLIENT_SECRET=...
# OIDC_REDIRECT_URI=https://deck.example.com/api/auth/oidc/callback
# OIDC_ALLOWED_DOMAINS=example.com            # optional: restrict to these email domains (comma-separated)
# OIDC_AUTO_PROVISION=true                    # JIT-create users on first login (default true)
# OIDC_DEFAULT_ROLE=user                      # role for provisioned users (user|admin)
# OIDC_ADMIN_GROUPS=deckyard-admins           # optional: IdP groups/roles that map to admin (comma-separated)
# SSO_ENFORCE=false                           # true = hide password + magic-link, SSO only

# ============================================
# ImageKit CDN (recommended for production)
# ============================================
# IMAGEKIT_PRIVATE_KEY=...
# IMAGEKIT_PUBLIC_KEY=...
# IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/youraccount

# ============================================
# Notion Integration (optional)
# ============================================
# NOTION_SECRET=...
# NOTION_FEATURE=true

# ============================================
# Live Data Sources (optional)
# ============================================
# Enable slides to connect to external data sources (Notion, CSV, Google Sheets)
# LIVE_DATA_ENABLED=true

# ============================================
# Email (Brevo/Sendinblue - optional)
# ============================================
# BREVO_API_KEY=...
# BREVO_SENDER_EMAIL=noreply@yourdomain.com
# BREVO_SENDER_NAME=Deckyard

# ============================================
# Database (PostgreSQL mode - optional)
# Default is file-based storage, no database needed
# ============================================
# STORAGE_MODE=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=deckyard
# DATABASE_USER=deckyard
# DATABASE_PASSWORD=...
# DATABASE_SSL=false
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# ============================================
# Stock Media (Unsplash & Giphy)
# ============================================
# UNSPLASH_ACCESS_KEY=your-unsplash-access-key
# GIPHY_API_KEY=your-giphy-api-key

# ============================================
# Sandbox mode (public throwaway playground)
# ============================================
# Turns the instance into an anonymous, self-cleaning demo (a la "try it"):
# guest sessions with an unguessable cookie, auto-cleanup after the TTL,
# watermarked exports, direct uploads and publishing off. Unsplash/Giphy stay
# on as stock sources (set the keys above). Use docker-compose.sandbox.yml,
# which wires these up. See server/config/sandbox.js and docs/ops/self-hosting.md.
# SANDBOX_MODE=1
# SANDBOX_TTL_HOURS=24
# SANDBOX_DEFAULT_THEME=editorial
# SANDBOX_COOKIE_DAYS=30
# SANDBOX_WATERMARK=Sandbox export • Created by an anonymous user
# Separate data/uploads dirs so the cleanup sweep only touches guest content.
# SANDBOX_DATA_DIR=server/data-sandbox
# SANDBOX_UPLOADS_DIR=server/uploads-sandbox

# ============================================
# Bunny Stream (optional - for video export)
# ============================================
# Enable MP4 embedding in PPTX exports for Bunny-hosted videos.
# Find your pull zone hostname in Bunny dashboard under Stream > Video Library > Pull Zone.
# Format: vz-xxxxxx-xxx.b-cdn.net (or just the subdomain: vz-xxxxxx-xxx)
# BUNNY_PULLZONE=vz-xxxxxx-xxx.b-cdn.net

# ============================================
# HTTPS/Domain (for Caddy reverse proxy)
# ============================================
# DOMAIN=slides.yourdomain.com
# LETSENCRYPT_EMAIL=admin@yourdomain.com
# Behind a trusted reverse proxy (Caddy, nginx), set TRUST_PROXY=true so the
# real client IP is read from X-Forwarded-For / X-Real-IP instead of the proxy's
# socket address. This is what the per-IP login brute-force throttle keys on, so
# without it every request looks like it comes from the proxy and the throttle
# treats all users as one client. Only enable it when a proxy you control sets
# those headers; a directly-exposed server must leave it off (spoofable).
# TRUST_PROXY=true

# ============================================
# Application URL (for outbound emails)
# ============================================
# Used in notification emails (export ready, digests, etc.)
# If not set, falls back to https://{DOMAIN} or relative URLs.
# APP_URL=https://slides.yourdomain.com

# ============================================
# Exports (server-rendered PDF)
# ============================================
# Timeout in ms for the headless-Chrome PDF render (setContent + page.pdf).
# Large decks with many embedded images can exceed Puppeteer's 30000ms default
# and fail with "Timed out after waiting 30000ms". Raise this if needed.
# 0 disables the cap (not recommended). Default: 120000.
# PDF_EXPORT_TIMEOUT_MS=120000
#
# Images are downsampled + recompressed (JPEG for opaque, PNG for transparent;
# SVGs/animated GIFs left alone) before being inlined, so a full-res photo does
# not drag its original pixels into the PDF. This typically shrinks exports by
# an order of magnitude. Longest edge is capped at PDF_EXPORT_IMAGE_MAX_PX
# (default 2600, a retina margin over the 1600px canvas) and opaque images are
# encoded at PDF_EXPORT_IMAGE_QUALITY (1-100, default 80). Set MAX_PX=0 or
# PDF_EXPORT_IMAGE_COMPRESSION=off to disable.
# PDF_EXPORT_IMAGE_MAX_PX=2600
# PDF_EXPORT_IMAGE_QUALITY=80
# PDF_EXPORT_IMAGE_COMPRESSION=on
#
# Chromium sandbox. The Docker image runs the browser as a non-root user, so a
# renderer compromise is contained without root. Chromium's own sandbox is OFF
# by default because its namespace sandbox needs syscalls that Docker's default
# seccomp profile blocks (a sandboxed launch would fail and break export). If
# you harden the runtime (e.g. run with `--cap-add=SYS_ADMIN` or a Chromium
# seccomp profile), set PUPPETEER_SANDBOX=true to re-enable it for extra
# defense-in-depth.
# PUPPETEER_SANDBOX=false
