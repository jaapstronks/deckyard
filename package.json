{
  "name": "deckyard",
  "version": "1.1.0",
  "description": "Self-hosted presentation engine for humans and AI agents (MCP-native)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaapstronks/deckyard.git"
  },
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "node --test 'tests/**/*.test.js'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:deadcode": "eslint . --config eslint.deadcode.config.js",
    "audit": "node scripts/audit-codebase.js",
    "db:migrate": "node server/db/migrate.js up",
    "db:migrate:down": "node server/db/migrate.js down",
    "db:migrate:status": "node server/db/migrate.js status",
    "db:migrate:data": "node scripts/migrate-data-to-postgres.js",
    "i18n:audit": "node scripts/i18n-audit.js",
    "i18n:extract": "node scripts/i18n-extract.js",
    "i18n:merge": "node scripts/i18n-merge.js",
    "i18n:sync": "node scripts/i18n-sync.js",
    "i18n:validate": "node scripts/i18n-validate.js",
    "start": "node server/server.js",
    "setup": "node scripts/setup.js",
    "seed:bg-demo": "node scripts/seed-bg-contrast-demo.js",
    "capture": "node capture/run.js",
    "mcp": "node server/mcp/index.js",
    "vendor:collab": "npx -y esbuild scripts/collab-vendor-entry.js --bundle --format=esm --platform=browser --minify --legal-comments=none --banner:js='/* Vendored bundle: yjs + @hocuspocus/provider (ESM, browser). Generated by `npm run vendor:collab` - do not edit by hand. */' --outfile=client/vendor/collab.js",
    "postinstall": "node scripts/vendor-lucide.js && node scripts/download-google-fonts.js",
    "test:ai-suite": "node --env-file=.env test-suite/runner/run.js",
    "ai-suite:fetch": "node --env-file=.env test-suite/scripts/fetch-cases.js",
    "ai-suite:parse-refs": "node test-suite/scripts/parse-reference.js",
    "ai-suite:stage": "node --env-file=.env test-suite/runner/stage.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@hocuspocus/provider": "^4.4.0",
    "@hocuspocus/server": "^4.4.0",
    "bullmq": "^5.30.0",
    "dompurify": "^3.2.2",
    "feed": "^5.2.0",
    "ioredis": "^5.4.1",
    "jsdom": "^25.0.0",
    "jszip": "^3.10.1",
    "kysely": "^0.28.17",
    "lucide-static": "^0.469.0",
    "mammoth": "^1.11.0",
    "openid-client": "^6.8.4",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.1",
    "pptxgenjs": "^3.12.0",
    "puppeteer-core": "^24.0.0",
    "sharp": "^0.35.3",
    "yaml": "^2.8.2",
    "yjs": "^13.6.31",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@eslint/js": "^9.39.5",
    "eslint": "^9.39.5",
    "eslint-plugin-import-x": "^4.17.1",
    "globals": "^17.7.0"
  }
}
